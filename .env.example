# ── PurrfectPal Studio – Docker Compose Secrets ──────────────────────────────
# Copy this file to .env and fill in the real values on the server.
# NEVER commit the .env file to git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Proxy / API Key ──────────────────────────────────────────────────────────
# Shared secret injected into every HTTP request by Nginx (X-Proxy-Key header)
PPS_KEY=your-strong-random-proxy-key-here

# ── MySQL Database ────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=your-strong-mysql-root-password
MYSQL_USER=adminPPS
MYSQL_PASSWORD=your-strong-db-password
MYSQL_DATABASE=purrfectpalstudiodb

# ── Certbot / Let's Encrypt ───────────────────────────────────────────────────
CERTBOT_EMAIL=your-email@example.com

# ── CI/CD Webhook ─────────────────────────────────────────────────────────────
# Must match the secret configured in your GitHub Webhook settings
WEBHOOK_SECRET=your-strong-webhook-secret

# GitHub Personal Access Token (fine-grained PAT: repo read-only)
GITHUB_PAT=

# Docker Hub credentials for pulling/pushing images
DOCKER_USER=manojshrees
DOCKER_PASS=

# GitHub token for the DB backup push service
GITHUB_TOKEN=
